# bribox Backend Environment Variables
# Copy this file to .env and update the values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=bribox
DB_PASSWORD=bribox_secret
DB_NAME=bribox_db
DB_SSLMODE=disable

# Server
SERVER_PORT=8080

# Security
JWT_SECRET=change-me-in-production-32chars!
ENCRYPTION_KEY=change-me-32-byte-key-for-aes!!

# CORS
ALLOW_ORIGINS=http://localhost:5173

# AI Services (Phase 4 & 5)
OPENAI_API_KEY=
IMAGE_AI_API_KEY=
