{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "BriBox desktop app capabilities — enables drag-drop, window controls, and event system",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
